{
  "name": "melty-tennis-monorepo",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @melty-tennis/melty-tennis dev",
    "build": "pnpm --filter @melty-tennis/melty-tennis build",
    "serve": "pnpm --filter @melty-tennis/melty-tennis serve",
    "test": "pnpm --filter @melty-tennis/melty-tennis test",
    "dev:model": "pnpm --filter @melty-tennis/model-tester dev",
    "build:model": "pnpm --filter @melty-tennis/model-tester build",
    "serve:model": "pnpm --filter @melty-tennis/model-tester serve",
    "test:model": "pnpm --filter @melty-tennis/model-tester test"
  }
}